{
  "name": "backend",
  "version": "0.8.7",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx src/server.ts",
    "dev:debug": "cross-env NODE_ENV=development tsx --inspect src/server.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "start:dev": "cross-env NODE_ENV=development node dist/server.js",
    "migrate": "cross-env NODE_ENV=development tsx src/migrate.ts",
    "migrate:prod": "cross-env NODE_ENV=production tsx src/migrate.ts",
    "migrate:test": "cross-env NODE_ENV=test tsx src/migrate.ts",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --config jest.config.mjs",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --config jest.config.mjs --testPathPatterns='api/'",
    "test:unit:watch": "cross-env NODE_ENV=test jest --watch",
    "test:unit:coverage": "cross-env NODE_ENV=test jest --coverage",
    "lint": "eslint .",
    "build:dev": "cross-env NODE_ENV=development tsc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-jest": "^30.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "jest": "^30.3.0",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  }
}